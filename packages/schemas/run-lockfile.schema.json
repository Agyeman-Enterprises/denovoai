{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunLockfile",
  "type": "object",
  "required": ["mode", "modules", "channel", "generated_at"],
  "properties": {
    "mode": { "type": "string" },
    "features": { "type": "array", "items": { "type": "string" } },
    "allowExperimental": { "type": "boolean" },
    "channel": { "type": "string", "enum": ["stable", "experimental"] },
    "modules": {
      "type": "object",
      "patternProperties": {
        "^.*$": { "type": "string" }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
