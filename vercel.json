{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/studio && npm run build",
  "devCommand": "cd apps/studio && npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": "apps/studio/.next",
  "functions": {
    "apps/studio/app/**": {
      "runtime": "nodejs18.x"
    }
  }
}
