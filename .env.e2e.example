# Denovo AI — E2E Test Environment
# Copy to .env.e2e and fill in values before running tests

# App URL (default: local dev server)
E2E_URL=http://localhost:3004

# Auth credentials (required for auth/session/permissions/checkout tests)
# Create a test account in Supabase first, then put credentials here
E2E_EMAIL=test@example.com
E2E_PASSWORD=testpassword123

# Stripe (required for checkout test — leave blank to skip)
E2E_STRIPE_KEY=
