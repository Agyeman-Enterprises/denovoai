{
  "_comment": "Copy to e2e/functional-config.json in each repo and fill in app-specific values.",
  "_doc": "Used by 11.functional-e2e.spec.ts (Gate 15) and 12.routes-and-apis.spec.ts (Gate 16).",

  "appName": "MyApp",

  "entities": [
    {
      "_comment": "One entry per primary entity. At least one required.",
      "name": "appointment",
      "listRoute": "/appointments",
      "createRoute": "/appointments/new",
      "apiListEndpoint": "/api/appointments",
      "apiSingleEndpoint": "/api/appointments/{id}",
      "createFields": [
        { "testid": "patient-name-input", "value": "E2E Test Patient" },
        { "testid": "appointment-date-input", "value": "2099-01-15" },
        { "testid": "appointment-time-input", "value": "10:00" },
        { "testid": "notes-input", "value": "e2e auto-generated — safe to delete" }
      ],
      "updateFields": [
        { "testid": "notes-input", "value": "e2e updated — safe to delete" }
      ],
      "submitButtonTestid": "submit-appointment-btn",
      "successMarkerTestid": "appointment-success-toast",
      "listItemTestid": "appointment-row",
      "deleteButtonTestid": "delete-appointment-btn",
      "deleteConfirmTestid": "confirm-delete-btn",
      "editRoute": "/appointments/{id}/edit",
      "editLinkTestid": "edit-appointment-link"
    }
  ],

  "pages": [
    {
      "_comment": "Every page the app should have. Test will FAIL if route returns 404 or renders nothing.",
      "path": "/",
      "expectedContentPattern": ".",
      "requiresAuth": false
    },
    {
      "path": "/login",
      "expectedContentPattern": ".",
      "requiresAuth": false
    },
    {
      "path": "/dashboard",
      "expectedContentPattern": ".",
      "requiresAuth": true
    },
    {
      "path": "/appointments",
      "expectedContentPattern": ".",
      "requiresAuth": true
    },
    {
      "path": "/profile",
      "expectedContentPattern": ".",
      "requiresAuth": true
    }
  ],

  "apiEndpoints": [
    {
      "_comment": "API route verification. Method, path, expected status with/without auth.",
      "path": "/api/appointments",
      "method": "GET",
      "authedStatus": 200,
      "unauthStatus": 401,
      "description": "List appointments for authenticated user"
    },
    {
      "path": "/api/profile",
      "method": "GET",
      "authedStatus": 200,
      "unauthStatus": 401,
      "description": "Get user profile"
    },
    {
      "path": "/api/appointments",
      "method": "POST",
      "authedStatus": 201,
      "unauthStatus": 401,
      "description": "Create appointment",
      "sampleBody": { "patient_name": "test", "appointment_date": "2099-01-15" }
    }
  ],

  "authRoutes": [
    {
      "_comment": "Routes that must redirect to /login when accessed without auth.",
      "path": "/dashboard"
    },
    {
      "path": "/appointments"
    },
    {
      "path": "/profile"
    }
  ],

  "criticalWorkflow": {
    "_comment": "Step-by-step flow that defines the app's primary value. MUST complete end-to-end.",
    "name": "Book an appointment",
    "steps": [
      {
        "description": "Navigate to appointments page",
        "action": "navigate",
        "target": "/appointments"
      },
      {
        "description": "Click new appointment button",
        "action": "click",
        "testid": "new-appointment-btn"
      },
      {
        "description": "Fill patient name",
        "action": "fill",
        "testid": "patient-name-input",
        "value": "Google QA Test Patient"
      },
      {
        "description": "Fill appointment date",
        "action": "fill",
        "testid": "appointment-date-input",
        "value": "2099-01-15"
      },
      {
        "description": "Submit form",
        "action": "click",
        "testid": "submit-appointment-btn"
      }
    ],
    "completionMarkerTestid": "appointment-success-toast",
    "completionMarkerText": ""
  },

  "fileOperations": {
    "_comment": "Set enabled:true only if the app supports these operations.",
    "upload": {
      "enabled": false,
      "route": "/documents/upload",
      "inputTestid": "file-upload-input",
      "successTestid": "upload-success",
      "sampleFileName": "test-document.pdf",
      "sampleFileContent": "Test document content for e2e"
    },
    "download": {
      "enabled": false,
      "route": "/documents/{id}/download",
      "triggerTestid": "download-btn",
      "expectedFilenamePattern": "\\.pdf$"
    },
    "export": {
      "enabled": false,
      "route": "/api/export",
      "triggerTestid": "export-btn",
      "expectedContentType": "text/csv"
    },
    "import": {
      "enabled": false,
      "route": "/api/import",
      "inputTestid": "import-file-input",
      "successTestid": "import-success",
      "sampleFileName": "import-test.csv",
      "sampleFileContent": "id,name\n1,test"
    }
  },

  "emailOperations": {
    "_comment": "Set enabled:true if app sends email that can be verified (OTP, confirmation, etc.).",
    "otpFlow": {
      "enabled": false,
      "description": "User requests OTP → receives email → enters code → lands on dashboard",
      "emailInputTestid": "email-input",
      "otpInputTestid": "otp-input",
      "otpValue": "__MANUAL_CHECK__",
      "successRoute": "/dashboard"
    },
    "inviteFlow": {
      "enabled": false,
      "triggerTestid": "invite-user-btn",
      "emailFieldTestid": "invite-email-input",
      "testEmail": "e2e-invite-test@example.com",
      "successTestid": "invite-sent-toast"
    }
  },

  "printOperations": {
    "_comment": "Set enabled:true if app has print/PDF export functionality.",
    "enabled": false,
    "triggerTestid": "print-btn",
    "description": "Print/PDF export of primary entity"
  },

  "navigationLinks": [
    {
      "_comment": "Every nav link must exist, be clickable, and resolve without error.",
      "label": "Dashboard",
      "testid": "nav-dashboard",
      "expectedRoute": "/dashboard"
    },
    {
      "label": "Appointments",
      "testid": "nav-appointments",
      "expectedRoute": "/appointments"
    },
    {
      "label": "Profile",
      "testid": "nav-profile",
      "expectedRoute": "/profile"
    },
    {
      "label": "Logout",
      "testid": "nav-logout",
      "expectedRoute": "/login"
    }
  ]
}
